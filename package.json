{
  "name": "signal.ts",
  "version": "1.0.0",
  "description": "Tiny fine-grained reactive signals for TypeScript.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gribbet/signal.ts.git"
  },
  "homepage": "https://github.com/gribbet/signal.ts#readme",
  "bugs": {
    "url": "https://github.com/gribbet/signal.ts/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint --max-warnings 0 --cache --cache-strategy content .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@gribbet/eslint-config": "github:gribbet/eslint-config",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3"
  }
}
